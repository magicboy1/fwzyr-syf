# Copy to .env and fill in real values. NEVER commit the real .env.
# Node 20.6+ can load this directly:  node --env-file=.env dist/index.cjs

# Required: admin password for the question-management UI (/admin).
# Without it, admin endpoints stay disabled.
ADMIN_PASSWORD=change-me-to-a-strong-password

# Port the server listens on (default 5000).
PORT=5000

# Bind address (default 0.0.0.0). Use 127.0.0.1 if you put nginx in front.
HOST=0.0.0.0

# Memory cap for the Node process (event runs comfortably under 512MB).
NODE_OPTIONS=--max-old-space-size=512
